PROJECT_NAME="Multi-IA Consultant"

# Sécurité
SECRET_KEY="VOTRE_SECRET_KEY_A_CHANGER"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Base de données
MONGODB_URL="mongodb://localhost:27017"
DATABASE_NAME="multiia_db"

# LLM Provider Configuration
# Options: "ollama" or "openrouter"
DEFAULT_LLM_PROVIDER="ollama"

# Configuration Ollama
OLLAMA_URL="http://localhost:11434"
OLLAMA_TIMEOUT=120.0
DEFAULT_MODEL_NAME="deepseek-v3.1:671b-cloud"

# Configuration OpenRouter
OPENROUTER_API_KEY="your-openrouter-api-key-here"
OPENROUTER_DEFAULT_MODEL="deepseek/deepseek-chat"
OPENROUTER_SITE_URL="http://localhost:5173"

# Paramètres du Modèle
MODEL_TEMPERATURE=0.7
MODEL_TOP_P=0.9
MODEL_TOP_K=40
MODEL_REPEAT_PENALTY=1.1
MODEL_NUM_PREDICT=1024
MODEL_NUM_CTX=4096

# Serveur et API
DEBUG=True
